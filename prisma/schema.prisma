generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(auto()) @map("_id") @db.ObjectId
  name                  String?
  email                 String?         @unique
  emailVerified         DateTime?
  image                 String?
  onboardingCompletedAt DateTime?
  // Email-digest delivery preferences. digestDeliveryHour is 0-23 in their tz.
  digestEmailEnabled    Boolean         @default(false)
  digestDeliveryHour    Int             @default(8)
  digestTimezone        String?
  // Per-day send-cadence guard: the local-day key "YYYY-MM-DD" (in the user's
  // tz) of the last digest we sent. DST-safe — see app/api/_shared/delivery.ts.
  lastDigestSentOn      String?
  // Summarization preferences. summaryLength tunes the AI prompt verbosity.
  // BYOK: when aiProvider != "default", summaries use the user's own key
  // (aiApiKeyCiphertext, AES-256-GCM via lib/crypto.ts) on the chosen provider;
  // otherwise the app's default Gemini key is used. Ciphertext NEVER leaves the
  // server — the API exposes only a derived `hasCustomKey` boolean.
  summaryLength         String          @default("standard")
  aiProvider            String          @default("default")
  aiModel               String?
  aiApiKeyCiphertext    String?
  accounts              Account[]
  sessions              Session[]
  watchedSenders        WatchedSender[]
  digests               Digest[]
  syncCursors           SyncCursor[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Waitlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("waitlist")
}

model WatchedSender {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  senderEmail String
  senderName  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderEmail])
  @@index([userId, isActive])
  @@map("watched_senders")
}

// Embedded summary produced by the AI layer (MongoDB composite type).
type DigestSummary {
  title              String
  tldr               String
  takeaways          String[]
  readingTimeMinutes Int
  tone               String
}

model Digest {
  id                   String         @id @default(auto()) @map("_id") @db.ObjectId
  userId               String         @db.ObjectId
  senderEmail          String
  gmailMessageId       String
  gmailThreadId        String?
  subject              String
  receivedAt           DateTime
  rawText              String
  summary              DigestSummary?
  summarizationPending Boolean        @default(true)
  summarizeAttempts    Int            @default(0)
  isRead               Boolean        @default(false)
  isSaved              Boolean        @default(false)
  createdAt            DateTime       @default(now())
  // Exactly-once content guard: set when this digest is included in a sent
  // email so it never appears in a second one. Null = not yet emailed.
  deliveredAt          DateTime?
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // LOAD-BEARING idempotency guard — one digest per Gmail message per user.
  @@unique([userId, gmailMessageId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, isSaved, createdAt(sort: Desc)])
  @@index([userId, deliveredAt])
  @@index([summarizationPending, summarizeAttempts])
  @@map("digests")
}

model SyncCursor {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  senderEmail      String
  lastInternalDate DateTime
  lastHistoryId    String?
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderEmail])
  @@map("sync_cursors")
}
